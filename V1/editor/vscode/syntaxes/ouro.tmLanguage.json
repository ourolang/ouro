{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "Ouro",
  "scopeName": "source.ouro",
  "fileTypes": ["ou"],
  "patterns": [
    { "include": "#asm-block" },
    { "include": "#comments" },
    { "include": "#triple-strings" },
    { "include": "#strings" },
    { "include": "#byte-literal" },
    { "include": "#numbers" },
    { "include": "#keywords" },
    { "include": "#builtin-types" },
    { "include": "#dunders" },
    { "include": "#function-definition" },
    { "include": "#struct-definition" },
    { "include": "#import" },
    { "include": "#type-names" },
    { "include": "#function-call" },
    { "include": "#operators" },
    { "include": "#identifiers" }
  ],
  "repository": {
    "comments": {
      "patterns": [
        {
          "name": "comment.line.number-sign.ouro",
          "match": "#.*$"
        }
      ]
    },
    "triple-strings": {
      "name": "string.quoted.triple.ouro",
      "begin": "\"\"\"",
      "end": "\"\"\"",
      "patterns": [
        { "include": "#string-escapes" }
      ]
    },
    "strings": {
      "name": "string.quoted.double.ouro",
      "begin": "\"",
      "end": "\"",
      "patterns": [
        { "include": "#string-escapes" }
      ]
    },
    "string-escapes": {
      "patterns": [
        {
          "name": "constant.character.escape.ouro",
          "match": "\\\\(n|r|t|0|\\\\|'|\"|x[0-9A-Fa-f]{2})"
        },
        {
          "name": "invalid.illegal.escape.ouro",
          "match": "\\\\."
        }
      ]
    },
    "byte-literal": {
      "patterns": [
        {
          "name": "string.quoted.single.ouro",
          "match": "'(\\\\(n|r|t|0|\\\\|'|\"|x[0-9A-Fa-f]{2})|[^'\\\\])'"
        }
      ]
    },
    "numbers": {
      "patterns": [
        {
          "name": "constant.numeric.float.ouro",
          "match": "\\b\\d[\\d_]*\\.\\d[\\d_]*(?:[eE][+-]?\\d[\\d_]*)?(?:f32|f64)?\\b"
        },
        {
          "name": "constant.numeric.float.ouro",
          "match": "\\b\\d[\\d_]*[eE][+-]?\\d[\\d_]*(?:f32|f64)?\\b"
        },
        {
          "name": "constant.numeric.integer.hex.ouro",
          "match": "\\b0x[0-9A-Fa-f_]+(?:i8|i16|i32|i64|u8|u16|u32|u64|isize|usize)?\\b"
        },
        {
          "name": "constant.numeric.integer.binary.ouro",
          "match": "\\b0b[01_]+(?:i8|i16|i32|i64|u8|u16|u32|u64|isize|usize)?\\b"
        },
        {
          "name": "constant.numeric.integer.octal.ouro",
          "match": "\\b0o[0-7_]+(?:i8|i16|i32|i64|u8|u16|u32|u64|isize|usize)?\\b"
        },
        {
          "name": "constant.numeric.integer.decimal.ouro",
          "match": "\\b\\d[\\d_]*(?:i8|i16|i32|i64|u8|u16|u32|u64|isize|usize)?\\b"
        }
      ]
    },
    "operators": {
      "patterns": [
        {
          "name": "keyword.operator.bitwise.ouro",
          "match": "<<|>>|\\&|\\^|\\|"
        }
      ]
    },
    "keywords": {
      "patterns": [
        {
          "name": "keyword.control.ouro",
          "match": "\\b(if|elif|else|match|for|in|return|pass|break|continue|loop|while)\\b"
        },
        {
          "name": "keyword.declaration.ouro",
          "match": "\\b(fn|struct|import|asm|extern|type)\\b"
        },
        {
          "name": "storage.modifier.ouro",
          "match": "\\b(var|const|weak|ptr|rc|arc)\\b"
        },
        {
          "name": "constant.language.boolean.ouro",
          "match": "\\b(true|false)\\b"
        },
        {
          "name": "variable.language.self.ouro",
          "match": "\\b(self|Self)\\b"
        },
        {
          "name": "keyword.operator.logical.ouro",
          "match": "\\b(and|or|not)\\b"
        }
      ]
    },
    "builtin-types": {
      "patterns": [
        {
          "name": "support.type.primitive.ouro",
          "match": "\\b(i8|i16|i32|i64|u8|u16|u32|u64|isize|usize|f32|f64|bool)\\b"
        },
        {
          "name": "support.type.error.ouro",
          "match": "\\b(NullError|StopIteration|EmptyError|ParseError)\\b"
        }
      ]
    },
    "dunders": {
      "patterns": [
        {
          "name": "support.function.dunder.ouro",
          "match": "\\b__[a-zA-Z][a-zA-Z0-9_]*__\\b"
        }
      ]
    },
    "asm-block": {
      "begin": "^(\\s*)(asm)\\s+([a-zA-Z_][a-zA-Z0-9_]*)\\s*\\(",
      "end": "^(?!\\1\\s)(?=\\S)",
      "beginCaptures": {
        "2": { "name": "keyword.declaration.ouro" },
        "3": { "name": "entity.name.function.ouro" }
      },
      "patterns": [
        { "include": "#asm-signature" },
        { "include": "#asm-body" }
      ]
    },
    "asm-signature": {
      "begin": "(?<=asm\\s+[a-zA-Z_][a-zA-Z0-9_]*\\s*\\()",
      "end": ":\\s*$",
      "patterns": [
        { "include": "#comments" },
        { "include": "#keywords" },
        { "include": "#builtin-types" },
        { "include": "#type-names" },
        { "include": "#identifiers" },
        { "include": "#operators" },
        { "include": "#numbers" }
      ]
    },
    "asm-body": {
      "patterns": [
        {
          "name": "comment.line.number-sign.asm.ouro",
          "match": "#.*$"
        },
        {
          "name": "variable.language.register.asm.ouro",
          "match": "%[a-zA-Z][a-zA-Z0-9]*"
        },
        {
          "name": "constant.numeric.immediate.asm.ouro",
          "match": "\\$-?(0x[0-9A-Fa-f]+|\\d+)"
        },
        {
          "name": "entity.name.label.asm.ouro",
          "match": "^\\s*\\.?[A-Za-z_][A-Za-z0-9_]*:"
        },
        {
          "name": "keyword.other.directive.asm.ouro",
          "match": "^\\s*\\.[A-Za-z_]+"
        }
      ]
    },
    "function-definition": {
      "match": "\\b(fn)\\s+([a-zA-Z_][a-zA-Z0-9_]*)",
      "captures": {
        "1": { "name": "keyword.declaration.ouro" },
        "2": { "name": "entity.name.function.ouro" }
      }
    },
    "struct-definition": {
      "match": "\\b(struct)\\s+([A-Z_][a-zA-Z0-9_]*)",
      "captures": {
        "1": { "name": "keyword.declaration.ouro" },
        "2": { "name": "entity.name.type.struct.ouro" }
      }
    },
    "import": {
      "match": "\\b([a-zA-Z_][a-zA-Z0-9_]*)\\s*=\\s*(import)\\b",
      "captures": {
        "1": { "name": "variable.other.module.ouro" },
        "2": { "name": "keyword.declaration.ouro" }
      }
    },
    "type-names": {
      "patterns": [
        {
          "name": "entity.name.type.ouro",
          "match": "\\b[A-Z][a-zA-Z0-9_]*\\b"
        }
      ]
    },
    "function-call": {
      "match": "\\b([a-zA-Z_][a-zA-Z0-9_]*)\\s*(?=\\()",
      "captures": {
        "1": { "name": "entity.name.function.call.ouro" }
      }
    },
    "operators": {
      "patterns": [
        {
          "name": "keyword.operator.type-test.ouro",
          "match": "\\?="
        },
        {
          "name": "keyword.operator.assignment.ouro",
          "match": "="
        },
        {
          "name": "keyword.operator.comparison.ouro",
          "match": "==|!=|<=|>=|<|>"
        },
        {
          "name": "keyword.operator.arithmetic.ouro",
          "match": "\\+|-|\\*|/|%"
        },
        {
          "name": "keyword.operator.bitwise.ouro",
          "match": "<<|>>|&|\\^|~"
        },
        {
          "name": "keyword.operator.union.ouro",
          "match": "\\|"
        },
        {
          "name": "keyword.operator.arrow.ouro",
          "match": "->"
        },
        {
          "name": "keyword.operator.range.ouro",
          "match": "\\.\\."
        },
        {
          "name": "keyword.operator.optional.ouro",
          "match": "\\?"
        }
      ]
    },
    "identifiers": {
      "patterns": [
        {
          "name": "variable.other.private.ouro",
          "match": "\\b_[a-zA-Z0-9_]*\\b"
        },
        {
          "name": "variable.other.ouro",
          "match": "\\b[a-zA-Z][a-zA-Z0-9_]*\\b"
        }
      ]
    }
  }
}
