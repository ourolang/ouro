# Recursive sum type — exactly the shape the bootstrap rewrite needs
# for AST nodes (Expr contains If contains Expr, etc.).  Boxing
# through `arc[Expr]` keeps the variants' sizes finite.
#
# Verifies:
#   - A union alias can recursively reference itself via `arc[T]`.
#   - Variants holding `arc[Expr]` build cleanly.
#   - Match arms discriminate on variant tag and unbox the payload.
#   - Drop walks the tree without leaking or double-freeing.
#
# v1 quirk: assigning a variant struct directly to a union-typed
# slot doesn't auto-box.  Workaround: wrap construction in fn calls
# — the `_emit_return` path boxes union returns correctly.  Once
# binding-site boxing lands, the helpers go away.

struct Lit:
    value: i32

struct Neg:
    inner: arc[Expr]

struct Plus:
    lhs: arc[Expr]
    rhs: arc[Expr]

Expr: type = Lit | Neg | Plus

fn lit(v: i32) -> arc[Expr]:
    return Lit { value: v }

fn neg(e: arc[Expr]) -> arc[Expr]:
    return Neg { inner: e }

fn plus(a: arc[Expr], b: arc[Expr]) -> arc[Expr]:
    return Plus { lhs: a, rhs: b }

fn eval(e: arc[Expr]) -> i32:
    match e:
        l: Lit: return l.value
        n: Neg: return -eval(n.inner)
        p: Plus: return eval(p.lhs) + eval(p.rhs)

fn main() -> i32:
    # Tree: -(3 + (4 + -2))  →  -(3 + 2)  →  -5
    root = neg(plus(lit(3), plus(lit(4), neg(lit(2)))))
    if eval(root) != -5:
        return 1
    return 0
