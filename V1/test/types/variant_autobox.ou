# Variant auto-box at binding time: assigning a specific variant
# value to a union-typed slot wraps it in a tagged box, so downstream
# match arms can dispatch on the tag.
#
# Previously this required wrapper fns (`fn lit(v: i32) -> arc[Expr]:
# return Lit { value: v }`) since only the union-return path boxed.

struct Lit:
    value: i32

struct Plus:
    lhs: arc[Expr]
    rhs: arc[Expr]

Expr: type = Lit | Plus

fn eval(e: arc[Expr]) -> i32:
    match e:
        l: Lit:  return l.value
        p: Plus: return eval(p.lhs) + eval(p.rhs)

fn main() -> i32:
    # Direct variant assignment to union slot — no helper fns needed.
    a: arc[Expr] = Lit { value: 3 }
    b: arc[Expr] = Lit { value: 4 }
    sum: arc[Expr] = Plus { lhs: a, rhs: b }

    if eval(sum) != 7:
        return 1
    if eval(a) != 3:
        return 2
    if eval(b) != 4:
        return 3
    return 0
