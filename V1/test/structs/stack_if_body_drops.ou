# An `if` body forms its own scope.  Allocations inside drop at the
# end of the branch, not at function exit.
io = import("std/io")

struct R:
    n: i32

    fn __drop__(self):
        io.printf("drop %d\n", self.n)

fn main() -> i32:
    if true:
        r = R { n: 1 }   # stack — drops at end of the if branch
    io.println("after")
    return 0
